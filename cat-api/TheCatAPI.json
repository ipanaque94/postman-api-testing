                  "pm.test(\"📋 Response es un array\", () => {\r",
                  "    pm.expect(pm.response.json()).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"📦 Array no está vacío\", () => {\r",
                  "    pm.expect(pm.response.json().length).to.be.above(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"🐱 Todas las razas tienen propiedades requeridas\", () => {\r",
                  "    const breeds = pm.response.json();\r",
                  "    breeds.forEach(breed => {\r",
                  "        pm.expect(breed).to.have.property(\"id\");\r",
                  "        pm.expect(breed).to.have.property(\"name\");\r",
                  "        pm.expect(breed).to.have.property(\"temperament\");\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "const firstBreed = pm.response.json()[0];\r",
                  "pm.environment.set(\"first_breed_id\", firstBreed.id);\r",
                  "pm.environment.set(\"first_breed_name\", firstBreed.name);\r",
                  "console.log(\"💾 Raza guardada:\", firstBreed.name, \"| ID:\", firstBreed.id);"
